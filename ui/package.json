{
  "name": "requirement-atomizer-desktop-ui",
  "version": "0.1.0",
  "private": true,
  "description": "标准需求抽取与审查平台 Vue3 桌面界面。",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop:dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "backend:build": "powershell -ExecutionPolicy Bypass -File ../packaging/build-electron-backend.ps1",
    "desktop:pack": "npm run backend:build && npm run build && electron-builder --win portable",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "@lucide/vue": "^1.20.0",
    "naive-ui": "^2.40.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.requirementatomizer.desktop",
    "productName": "标准需求抽取与审查平台",
    "asar": true,
    "win": {
      "signAndEditExecutable": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "..", "to": ".", "filter": ["*.py"] },
      { "from": "../parsers", "to": "parsers" },
      { "from": "../requirement_kb", "to": "requirement_kb" },
      { "from": "../domain_packs", "to": "domain_packs" },
      { "from": "../knowledge_bases", "to": "knowledge_bases" },
      { "from": "../llm_agents", "to": "llm_agents" },
      { "from": "../dist-backend", "to": "backend" }
    ]
  }
}
