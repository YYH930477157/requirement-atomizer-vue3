{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atomic Requirement Candidate",
  "type": "object",
  "required": [
    "req_id",
    "stable_req_id",
    "source_id",
    "source_type",
    "source_refs",
    "domain",
    "object",
    "requirement_type",
    "requirement",
    "verification_method",
    "ambiguity",
    "confidence",
    "generated_by"
  ],
  "properties": {
    "req_id": {"type": "string", "pattern": "^AREQ-[0-9]{6}$"},
    "stable_req_id": {"type": "string", "pattern": "^SREQ-[0-9A-F]{16}$"},
    "source_id": {"type": "string", "minLength": 1},
    "source_type": {"type": "string", "minLength": 1},
    "source_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "section_path": {"type": "array", "items": {"type": "string"}},
    "domain": {"type": "string", "minLength": 1},
    "domain_tags": {"type": "array", "items": {"type": "string"}},
    "object": {"type": "string"},
    "requirement_type": {"type": "string", "minLength": 1},
    "requirement": {"type": "string", "minLength": 1},
    "condition": {"type": ["string", "null"]},
    "source_context": {
      "type": "object",
      "properties": {
        "paragraph_text": {"type": "string"},
        "prev_sentence": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "parameters": {"type": "object"},
    "verification_method": {"type": "string", "minLength": 1},
    "ambiguity": {"type": "boolean"},
    "review_questions": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "kb_matches": {"type": "array", "items": {"type": "object"}},
    "generated_by": {"type": "string", "minLength": 1},
    "domain_pack_id": {"type": "string"},
    "pattern_id": {"type": "string"},
    "generic_type": {"type": "string"}
  },
  "additionalProperties": true
}
